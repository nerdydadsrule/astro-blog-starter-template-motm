---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Moth on the Moon | Handcrafted Jewelry">
  <!-- Hero Section -->
  <section class="hero">
    <h1>Wearable Magic for the Wild at Heart</h1>
    <p>Handcrafted jewelry inspired by the night, the moon, and the transformation of the moth.</p>
    <a href="/shop" class="cta-button">Shop the Collection</a>
  </section>

  <!-- Featured Categories -->
  <section class="categories">
    <div class="category">
      <h3>Celestial Pendants</h3>
      <p>Wire-wrapped stones featuring lunar phases.</p>
    </div>
    <div class="category">
      <h3>Nature’s Fragments</h3>
      <p>Resin-preserved botanicals and pressed flowers.</p>
    </div>
    <div class="category">
      <h3>The Gemstone Gallery</h3>
      <p>Hand-selected Labradorite and Moonstone.</p>
    </div>
  </section>
</BaseLayout>
