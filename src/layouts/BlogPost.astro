---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <style>
      /* Add your "darkly whimsical" CSS here */
      body { background: #1a1a1a; color: #f4f4f4; font-family: 'Georgia', serif; }
      .cta-button { background: #d4af37; color: #1a1a1a; padding: 1rem 2rem; text-decoration: none; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/shop">Shop</a>
    </nav>
    <main>
      <slot /> <!-- This is where page content goes -->
    </main>
    <footer>
      <p>&copy; 2024 Moth on the Moon by Amanda Cobb</p>
    </footer>
  </body>
</html>

